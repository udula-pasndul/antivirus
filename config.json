{
    "scan_settings": {
        "deep_analysis_enabled": true,
        "behavioral_monitoring": true,
        "rootkit_detection": true,
        "memory_analysis": true,
        "network_deep_inspection": true
    },
    "thresholds": {
        "high_cpu_threshold": 80,
        "high_memory_threshold": 500,
